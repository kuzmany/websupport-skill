#!/usr/bin/env bash
# websupport — thin wrapper around the bundled Websupport REST API client.
# Resolves its own real path (so it works when symlinked into ~/bin) and execs
# skills/websupport/scripts/ws_api.py with whatever args you pass.
#
#   websupport whoami
#   websupport check mojadomena.sk
#   websupport prices --market sk
#
# Needs: python3, and the env vars WEBSUPPORT_API_KEY / WEBSUPPORT_API_SECRET.
set -euo pipefail
SELF="$(readlink -f "$0")"
ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"
exec python3 "$ROOT/skills/websupport/scripts/ws_api.py" "$@"
